# API Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=True

# External API Keys (Get keys from respective providers)
SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key
WHOIS_API_KEY=your_whois_api_key_if_using_external_provider

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phishing_detector
DB_USER=postgres
DB_PASSWORD=your_password

# Redis Configuration for Caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Model Configuration
MODEL_PATH=data/models/
LOG_LEVEL=INFO

# Security
SECRET_KEY=your_secret_key_for_jwt_tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
